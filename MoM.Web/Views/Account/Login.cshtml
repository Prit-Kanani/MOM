@model MoM.Web.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<section class="auth-shell">
    <div class="auth-card glass-card">
        <div>
            <div class="hero-kicker">Secure Access</div>
            <h1>Sign in to your MOM workspace</h1>
            <p>Login to access dashboard analytics, Meeting Vault, editor, preview, and PDF export.</p>
        </div>

        <form asp-action="Login" method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

            <div asp-validation-summary="ModelOnly" class="auth-validation"></div>

            <div class="form-group">
                <label asp-for="UserName" class="form-label"></label>
                <input asp-for="UserName" class="form-input" autocomplete="username" />
                <span asp-validation-for="UserName" class="field-validation"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-input" autocomplete="current-password" />
                <span asp-validation-for="Password" class="field-validation"></span>
            </div>

            <button type="submit" class="btn-primary auth-submit">Login</button>
        </form>

        <div class="auth-footer-copy">
            New here?
            <a asp-action="Register">Create an account</a>
        </div>
    </div>
</section>
