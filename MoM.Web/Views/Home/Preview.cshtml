@{
    ViewData["Title"] = "Preview MOM";
}

<div class="glass-card preview-shell">
    <div class="preview-actions">
        <a href="@Url.Action("Dashboard", "Home")" class="editor-back-link">
            <i class="fas fa-arrow-left"></i>
            <span>Back to Dashboard</span>
        </a>
        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
            <a href="/Home/Editor?id=@ViewBag.MeetingId" class="btn-link">Edit MOM</a>
            <a href="/mom-api/export/@ViewBag.MeetingId" target="_blank" class="btn-primary" style="text-decoration: none;">Export PDF</a>
        </div>
    </div>

    <div id="previewContent" class="preview-card">
        Loading MOM preview...
    </div>
</div>

@section Scripts {
    <script>
        const API_URL = '/mom-api';
        const meetingId = @ViewBag.MeetingId;

        function escapeHtml(value) {
            return (value || '')
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;')
                .replaceAll('"', '&quot;');
        }

        function renderList(items, emptyText, template) {
            if (!items.length) {
                return `<div class="preview-empty">${emptyText}</div>`;
            }

            return items.map(template).join('');
        }

        async function loadPreview() {
            try {
                const response = await fetch(`${API_URL}/meetings/${meetingId}`);
                if (!response.ok) {
                    throw new Error(`Request failed: ${response.status}`);
                }

                const data = await response.json();
                const content = document.getElementById('previewContent');
                content.innerHTML = `
                    <div class="preview-header">
                        <div>
                            <div class="hero-kicker">${escapeHtml(data.meetingType || 'Meeting')}</div>
                            <h1>${escapeHtml(data.title)}</h1>
                            <p>${escapeHtml(data.subject)}</p>
                        </div>
                    </div>

                    <div class="preview-grid">
                        <div class="preview-field"><span>Meeting No.</span><strong>${escapeHtml(data.meetingNumber || 'N/A')}</strong></div>
                        <div class="preview-field"><span>Date</span><strong>${new Date(data.date).toLocaleDateString()}</strong></div>
                        <div class="preview-field"><span>Time</span><strong>${escapeHtml(data.time || 'N/A')}</strong></div>
                        <div class="preview-field"><span>Venue</span><strong>${escapeHtml(data.venue?.name || 'N/A')}</strong></div>
                        <div class="preview-field"><span>Facilitator</span><strong>${escapeHtml(data.facilitator?.name || 'N/A')}</strong></div>
                        <div class="preview-field"><span>Chairperson</span><strong>${escapeHtml(data.chairperson?.name || 'N/A')}</strong></div>
                        <div class="preview-field"><span>Secretary</span><strong>${escapeHtml(data.secretary?.name || 'N/A')}</strong></div>
                        <div class="preview-field"><span>Present Count</span><strong>${data.presentCount || 0}</strong></div>
                        <div class="preview-field"><span>Absent Count</span><strong>${data.absentCount || 0}</strong></div>
                    </div>

                    <div class="preview-section">
                        <h2>Attendees</h2>
                        <div class="attendee-preview-list">
                            ${renderList(data.attendees || [], 'No attendees added.', attendee => `
                                <div class="attendee-pill ${attendee.isPresent ? 'attendee-present' : 'attendee-absent'}">
                                    <span>${escapeHtml(attendee.userName)}</span>
                                    <strong>${attendee.isPresent ? 'Present' : 'Absent'}</strong>
                                </div>
                            `)}
                        </div>
                    </div>

                    <div class="preview-section">
                        <h2>Agenda</h2>
                        ${renderList(data.agendas || [], 'No agenda items added.', agenda => `
                            <div class="preview-row-card">
                                <strong>${escapeHtml(agenda.topic)}</strong>
                                <span>${escapeHtml(agenda.owner?.name || 'No owner')}</span>
                            </div>
                        `)}
                    </div>

                    <div class="preview-section">
                        <h2>Action Items</h2>
                        ${renderList(data.actionItems || [], 'No action items added.', action => `
                            <div class="preview-row-card">
                                <strong>${escapeHtml(action.task)}</strong>
                                <span>${escapeHtml(action.responsibility?.name || 'No owner')}</span>
                                <small>${action.deadline ? new Date(action.deadline).toLocaleDateString() : 'No due date'}</small>
                            </div>
                        `)}
                    </div>
                `;
            } catch (error) {
                console.error('Preview load failed:', error);
                document.getElementById('previewContent').innerHTML = '<div class="preview-empty">Failed to load MOM preview.</div>';
            }
        }

        loadPreview();
    </script>
}
