@{
    ViewData["Title"] = "Best MOM Website Provider";
}

<section class="hero-shell">
    <div class="hero-card">
        <div class="hero-copy">
            <div class="hero-kicker">Best MOM Website Provider</div>
            <h1>Build, manage, and export Minutes of Meeting in one place.</h1>
            <p>
                Create MOM records section-wise, track attendee presence by name, and manage every meeting from a focused dashboard built for clean workflows.
            </p>
            <div class="hero-actions">
                <a asp-action="Dashboard" class="btn-primary" style="text-decoration: none;">Let's Get Started</a>
                <a asp-action="Dashboard" class="btn-link">Open Dashboard</a>
            </div>
        </div>
        <div class="hero-panel">
            <div class="hero-panel-title">What you can do</div>
            <div class="hero-feature">Create MOM records in one guided form</div>
            <div class="hero-feature">Track present and absent attendees by name</div>
            <div class="hero-feature">Export MOMs as PDF from the dashboard</div>
            <div class="hero-feature">Monitor meeting analytics in one place</div>
        </div>
    </div>
</section>
