@{
    ViewData["Title"] = "MOM Dashboard";
}

<section class="dashboard-hero glass-card">
    <div class="dashboard-hero-head">
        <div>
            <div class="hero-kicker">Analytics Dashboard</div>
            <h1>Meeting intelligence at a glance</h1>
            <p>Track meeting activity, attendance trends, and manage every MOM record from one workspace.</p>
        </div>
        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
            <a asp-action="Editor" class="btn-primary" style="text-decoration: none;">Create MOM</a>
        </div>
    </div>

    <div class="stats-grid" id="statsCards">
        <div class="stats-card">
            <span>Total Meetings</span>
            <strong id="totalMeetings" data-target="0">0</strong>
        </div>
        <div class="stats-card">
            <span>Total Present Attendees</span>
            <strong id="totalPresent" data-target="0">0</strong>
        </div>
        <div class="stats-card">
            <span>Total Absent Attendees</span>
            <strong id="totalAbsent" data-target="0">0</strong>
        </div>
    </div>

    <div class="chart-grid">
        <div class="chart-card">
            <div class="chart-title">Meetings Taken</div>
            <div id="meetingVolumeChart" class="bar-chart-empty">No meeting data yet.</div>
        </div>
        <div class="chart-card">
            <div class="chart-title">Present vs Absent Ratio</div>
            <div class="ratio-chart-wrap">
                <div id="attendanceRatioChart" class="ratio-chart"><span>No attendance data</span></div>
                <div class="ratio-legend">
                    <div><span class="legend-dot legend-present"></span>Present</div>
                    <div><span class="legend-dot legend-absent"></span>Absent</div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="glass-card">
    <div style="display: flex; justify-content: space-between; align-items: center;">
        <h2 style="margin: 0;">Saved MOM Records</h2>
    </div>

    <div class="table-shell">
        <table id="meetingsTable">
            <thead>
                <tr>
                    <th>Meeting No.</th>
                    <th>Meeting Type</th>
                    <th>Date</th>
                    <th>Subject</th>
                    <th>Present</th>
                    <th>Absent</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="meetingsList">
                <tr class="table-status-row">
                    <td colspan="7" style="text-align: center;">Loading meetings...</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        const API_URL = '/mom-api';

        async function loadStats() {
            try {
                const response = await fetch(`${API_URL}/meetings/stats`);
                if (!response.ok) {
                    throw new Error(`Request failed: ${response.status}`);
                }

                const stats = await response.json();
                animateCounter('totalMeetings', stats.totalMeetings || 0);
                animateCounter('totalPresent', stats.totalPresentAttendees || 0);
                animateCounter('totalAbsent', stats.totalAbsentAttendees || 0);

                renderMeetingVolume(stats.meetingVolume || []);
                animateAttendanceRatio(stats.totalPresentAttendees || 0, stats.totalAbsentAttendees || 0);
            } catch (error) {
                console.error('Stats load failed:', error);
            }
        }

        function animateCounter(id, target) {
            const element = document.getElementById(id);
            const duration = 900;
            const startTime = performance.now();

            function update(now) {
                const progress = Math.min((now - startTime) / duration, 1);
                const eased = 1 - Math.pow(1 - progress, 3);
                element.textContent = Math.round(target * eased);

                if (progress < 1) {
                    requestAnimationFrame(update);
                }
            }

            requestAnimationFrame(update);
        }

        function renderMeetingVolume(items) {
            const container = document.getElementById('meetingVolumeChart');
            if (!items.length) {
                container.className = 'bar-chart-empty';
                container.textContent = 'No meeting data yet.';
                return;
            }

            const maxValue = Math.max(...items.map(item => item.count), 1);
            container.className = 'bar-chart';
            container.innerHTML = items.map((item, index) => `
                <div class="bar-item">
                    <div class="bar-label">${item.label}</div>
                    <div class="bar-track">
                        <div class="bar-fill" style="--target-width:${(item.count / maxValue) * 100}%; animation-delay:${index * 120}ms;"></div>
                    </div>
                    <div class="bar-value">${item.count}</div>
                </div>
            `).join('');
        }

        function animateAttendanceRatio(present, absent) {
            const total = present + absent;
            const chart = document.getElementById('attendanceRatioChart');

            if (!total) {
                chart.style.background = 'rgba(67, 97, 238, 0.08)';
                chart.innerHTML = '<span>No attendance data</span>';
                return;
            }

            const targetPercent = Math.round((present / total) * 100);
            let currentPercent = 0;
            chart.innerHTML = '<span>0% Present</span>';

            function step() {
                currentPercent += Math.max(1, Math.ceil((targetPercent - currentPercent) / 10));
                if (currentPercent > targetPercent) {
                    currentPercent = targetPercent;
                }

                chart.style.background = `conic-gradient(#0f9b6f 0 ${currentPercent}%, #e0527a ${currentPercent}% 100%)`;
                chart.innerHTML = `<span>${currentPercent}% Present</span>`;

                if (currentPercent < targetPercent) {
                    requestAnimationFrame(step);
                }
            }

            requestAnimationFrame(step);
        }

        async function loadMeetings() {
            try {
                const response = await fetch(`${API_URL}/meetings`);
                if (!response.ok) {
                    throw new Error(`Request failed: ${response.status}`);
                }

                const meetings = await response.json();
                const list = document.getElementById('meetingsList');

                if (meetings.length === 0) {
                    list.innerHTML = '<tr class="table-status-row"><td colspan="7" style="text-align: center;">No MOM records found. Create your first MOM to get started.</td></tr>';
                    return;
                }

                list.innerHTML = meetings.map(m => `
                    <tr>
                        <td data-label="Meeting No.">${m.meetingNumber || 'N/A'}</td>
                        <td data-label="Meeting Type">${m.meetingType || 'N/A'}</td>
                        <td data-label="Date">${new Date(m.date).toLocaleDateString()}</td>
                        <td data-label="Subject"><strong>${m.subject}</strong></td>
                        <td data-label="Present">${m.presentCount}</td>
                        <td data-label="Absent">${m.absentCount}</td>
                        <td data-label="Actions" class="actions-cell" style="display: flex; gap: 10px; flex-wrap: wrap;">
                            <a href="/Home/Preview/${m.id}" class="action-icon action-view" title="Preview MOM" aria-label="Preview MOM">
                                <i class="fas fa-eye"></i>
                            </a>
                            <a href="/Home/Editor?id=${m.id}" class="action-icon action-edit" title="Edit MOM" aria-label="Edit MOM">
                                <i class="fas fa-pen-to-square"></i>
                            </a>
                            <a href="${API_URL}/export/${m.id}" target="_blank" class="action-icon action-export" title="Export PDF" aria-label="Export PDF">
                                <i class="fas fa-file-arrow-down"></i>
                            </a>
                            <button type="button" onclick="deleteMeeting(${m.id})" class="action-icon action-delete" title="Delete MOM" aria-label="Delete MOM">
                                <i class="fas fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                `).join('');
            } catch (error) {
                console.error('Error loading meetings:', error);
                document.getElementById('meetingsList').innerHTML = '<tr class="table-status-row"><td colspan="7" style="text-align: center; color: red;">Failed to load meetings. Make sure the API is running.</td></tr>';
            }
        }

        async function deleteMeeting(id) {
            if (!confirm('Are you sure you want to delete this meeting?')) {
                return;
            }

            try {
                const response = await fetch(`${API_URL}/meetings/${id}`, { method: 'DELETE' });
                if (!response.ok) {
                    throw new Error(`Delete failed: ${response.status}`);
                }

                loadMeetings();
                loadStats();
            } catch (error) {
                console.error('Delete error:', error);
                alert('Error deleting MOM record.');
            }
        }

        loadStats();
        loadMeetings();
    </script>
}
