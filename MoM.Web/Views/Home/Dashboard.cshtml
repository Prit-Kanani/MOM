@{
    ViewData["Title"] = "MOM Dashboard";
}

<section class="dashboard-hero glass-card">
    <div class="dashboard-hero-head">
        <div>
            <div class="hero-kicker">Analytics Dashboard</div>
            <h1>Meeting intelligence at a glance</h1>
            <p>Track meeting activity, attendance trends, venue usage, and team participation from one focused analytics workspace.</p>
        </div>
        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
            <a asp-action="MeetingVault" class="btn-link">Open Meeting Vault</a>
            <a asp-action="Editor" class="btn-primary" style="text-decoration: none;">Create MOM</a>
        </div>
    </div>

    <div class="stats-grid" id="statsCards">
        <div class="stats-card">
            <span>Total Meetings</span>
            <strong id="totalMeetings" data-target="0">0</strong>
        </div>
        <div class="stats-card">
            <span>Total Present Attendees</span>
            <strong id="totalPresent" data-target="0">0</strong>
        </div>
        <div class="stats-card">
            <span>Total Absent Attendees</span>
            <strong id="totalAbsent" data-target="0">0</strong>
        </div>
    </div>

    <div class="chart-grid">
        <div class="chart-card">
            <div class="chart-head">
                <div class="chart-title">Meetings Taken</div>
                <div class="chart-filter" role="tablist" aria-label="Meeting volume period">
                    <button type="button" class="chart-filter-btn is-active" data-period="month" onclick="changeMeetingVolumePeriod('month')">Month</button>
                    <button type="button" class="chart-filter-btn" data-period="week" onclick="changeMeetingVolumePeriod('week')">Week</button>
                    <button type="button" class="chart-filter-btn" data-period="year" onclick="changeMeetingVolumePeriod('year')">Year</button>
                </div>
            </div>
            <div id="meetingVolumeChart" class="bar-chart-empty">No meeting data yet.</div>
        </div>
        <div class="chart-card">
            <div class="chart-title">Present vs Absent Ratio</div>
            <div class="ratio-chart-wrap">
                <div class="ratio-chart-shell">
                    <div id="attendanceRatioChart" class="ratio-chart"><span>No attendance data</span></div>
                </div>
                <div class="ratio-legend">
                    <div id="presentLegend"><span class="legend-dot legend-present"></span>Present</div>
                    <div id="absentLegend"><span class="legend-dot legend-absent"></span>Absent</div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="analytics-stack">
    <div class="chart-card">
        <div class="section-head">
            <div>
                <div class="hero-kicker">User Insights</div>
                <h2>User Attendance Count</h2>
            </div>
        </div>
        <div id="userAttendanceChart" class="insight-list empty-state">No user attendance data yet.</div>
        <div id="userAttendancePagination" class="insight-pagination" hidden></div>
    </div>

    <div class="chart-card">
        <div class="section-head">
            <div>
                <div class="hero-kicker">Venue Insights</div>
                <h2>Venue-wise Meetings Count</h2>
            </div>
        </div>
        <div id="venueMeetingsChart" class="insight-list empty-state">No venue activity yet.</div>
        <div id="venueMeetingsPagination" class="insight-pagination" hidden></div>
    </div>
</section>

@section Scripts {
    <script>
        const API_URL = '/mom-api';
        const INSIGHT_PAGE_SIZE = 5;
        let meetingVolumePeriod = 'month';
        let userAttendanceItems = [];
        let venueMeetingItems = [];
        let userAttendancePage = 1;
        let venueMeetingsPage = 1;

        async function loadStats() {
            try {
                const response = await fetch(`${API_URL}/meetings/stats?period=${encodeURIComponent(meetingVolumePeriod)}`);
                if (!response.ok) {
                    throw new Error(`Request failed: ${response.status}`);
                }

                const stats = await response.json();
                animateCounter('totalMeetings', stats.totalMeetings || 0);
                animateCounter('totalPresent', stats.totalPresentAttendees || 0);
                animateCounter('totalAbsent', stats.totalAbsentAttendees || 0);

                renderMeetingVolume(stats.meetingVolume || []);
                animateAttendanceRatio(stats.totalPresentAttendees || 0, stats.totalAbsentAttendees || 0);

                userAttendanceItems = stats.userAttendance || [];
                venueMeetingItems = stats.venueMeetings || [];
                userAttendancePage = 1;
                venueMeetingsPage = 1;

                renderUserAttendance();
                renderVenueMeetings();
            } catch (error) {
                console.error('Stats load failed:', error);
            }
        }

        async function loadMeetingVolume() {
            try {
                const response = await fetch(`${API_URL}/meetings/stats?period=${encodeURIComponent(meetingVolumePeriod)}`);
                if (!response.ok) {
                    throw new Error(`Request failed: ${response.status}`);
                }

                const stats = await response.json();
                renderMeetingVolume(stats.meetingVolume || []);
            } catch (error) {
                console.error('Meeting volume load failed:', error);
            }
        }

        function changeMeetingVolumePeriod(period) {
            if (meetingVolumePeriod === period) {
                return;
            }

            meetingVolumePeriod = period;
            document.querySelectorAll('.chart-filter-btn').forEach(button => {
                button.classList.toggle('is-active', button.dataset.period === period);
            });
            loadMeetingVolume();
        }

        function animateCounter(id, target) {
            const element = document.getElementById(id);
            const duration = 900;
            const startTime = performance.now();

            function update(now) {
                const progress = Math.min((now - startTime) / duration, 1);
                const eased = 1 - Math.pow(1 - progress, 3);
                element.textContent = Math.round(target * eased);

                if (progress < 1) {
                    requestAnimationFrame(update);
                }
            }

            requestAnimationFrame(update);
        }

        function renderMeetingVolume(items) {
            const container = document.getElementById('meetingVolumeChart');
            if (!items.length) {
                container.className = 'bar-chart-empty';
                container.textContent = 'No meeting data yet.';
                return;
            }

            const maxValue = Math.max(...items.map(item => item.count), 1);
            container.className = 'bar-chart';
            container.innerHTML = items.map((item, index) => `
                <div class="bar-column" style="animation-delay:${index * 120}ms;">
                    <div class="bar-column-value">${item.count}</div>
                    <div class="bar-column-track">
                        <div class="bar-column-fill" style="--target-height:${Math.max((item.count / maxValue) * 100, 8)}%;"></div>
                    </div>
                    <div class="bar-column-label">${item.label}</div>
                </div>
            `).join('');
        }

        function animateAttendanceRatio(present, absent) {
            const total = present + absent;
            const chart = document.getElementById('attendanceRatioChart');
            const presentLegend = document.getElementById('presentLegend');
            const absentLegend = document.getElementById('absentLegend');

            if (!total) {
                chart.style.background = 'rgba(67, 97, 238, 0.08)';
                chart.innerHTML = '<span>No attendance data</span>';
                presentLegend.innerHTML = '<span class="legend-dot legend-present"></span>Present';
                absentLegend.innerHTML = '<span class="legend-dot legend-absent"></span>Absent';
                return;
            }

            const targetPresentPercent = Math.round((present / total) * 100);
            const targetAbsentPercent = 100 - targetPresentPercent;
            let currentPercent = 0;
            chart.innerHTML = '<span>0% Present</span>';

            function step() {
                currentPercent += Math.max(1, Math.ceil((targetPresentPercent - currentPercent) / 10));
                if (currentPercent > targetPresentPercent) {
                    currentPercent = targetPresentPercent;
                }

                chart.style.background = `conic-gradient(#0f9b6f 0 ${currentPercent}%, #e0527a ${currentPercent}% 100%)`;
                chart.innerHTML = `<span>${currentPercent}% Present</span>`;
                presentLegend.innerHTML = `<span class="legend-dot legend-present"></span>Present ${currentPercent}%`;
                absentLegend.innerHTML = `<span class="legend-dot legend-absent"></span>Absent ${100 - currentPercent}%`;

                if (currentPercent < targetPresentPercent) {
                    requestAnimationFrame(step);
                } else {
                    presentLegend.innerHTML = `<span class="legend-dot legend-present"></span>Present ${targetPresentPercent}%`;
                    absentLegend.innerHTML = `<span class="legend-dot legend-absent"></span>Absent ${targetAbsentPercent}%`;
                }
            }

            requestAnimationFrame(step);
        }

        function renderPagination(containerId, currentPage, totalItems, handlerName) {
            const container = document.getElementById(containerId);
            const totalPages = Math.ceil(totalItems / INSIGHT_PAGE_SIZE);

            if (totalPages <= 1) {
                container.hidden = true;
                container.innerHTML = '';
                return;
            }

            container.hidden = false;
            container.innerHTML = `
                <button type="button" class="pagination-btn" ${currentPage === 1 ? 'disabled' : ''} onclick="${handlerName}(${currentPage - 1})">
                    <i class="fas fa-chevron-left"></i>
                    <span>Prev</span>
                </button>
                <div class="pagination-indicator">Page ${currentPage} of ${totalPages}</div>
                <button type="button" class="pagination-btn" ${currentPage === totalPages ? 'disabled' : ''} onclick="${handlerName}(${currentPage + 1})">
                    <span>Next</span>
                    <i class="fas fa-chevron-right"></i>
                </button>
            `;
        }

        function changeUserAttendancePage(page) {
            userAttendancePage = page;
            renderUserAttendance();
        }

        function changeVenueMeetingsPage(page) {
            venueMeetingsPage = page;
            renderVenueMeetings();
        }

        function renderUserAttendance() {
            const container = document.getElementById('userAttendanceChart');
            if (!userAttendanceItems.length) {
                container.className = 'insight-list empty-state';
                container.textContent = 'No user attendance data yet.';
                renderPagination('userAttendancePagination', 1, 0, 'changeUserAttendancePage');
                return;
            }

            const start = (userAttendancePage - 1) * INSIGHT_PAGE_SIZE;
            const pagedItems = userAttendanceItems.slice(start, start + INSIGHT_PAGE_SIZE);
            container.className = 'insight-list';
            container.innerHTML = pagedItems.map((item, index) => `
                <div class="insight-row" style="animation-delay:${index * 90}ms;">
                    <div class="insight-copy">
                        <strong>${item.userName}</strong>
                    </div>
                    <div class="insight-meter">
                        <div class="insight-meter-fill" style="--target-width:${item.totalCount ? (item.presentCount / item.totalCount) * 100 : 0}%"></div>
                    </div>
                    <div class="insight-value">${item.presentCount}/${item.totalCount}</div>
                </div>
            `).join('');
            renderPagination('userAttendancePagination', userAttendancePage, userAttendanceItems.length, 'changeUserAttendancePage');
        }

        function renderVenueMeetings() {
            const container = document.getElementById('venueMeetingsChart');
            if (!venueMeetingItems.length) {
                container.className = 'insight-list empty-state';
                container.textContent = 'No venue activity yet.';
                renderPagination('venueMeetingsPagination', 1, 0, 'changeVenueMeetingsPage');
                return;
            }

            const start = (venueMeetingsPage - 1) * INSIGHT_PAGE_SIZE;
            const pagedItems = venueMeetingItems.slice(start, start + INSIGHT_PAGE_SIZE);
            const maxCount = Math.max(...venueMeetingItems.map(item => item.meetingCount), 1);
            container.className = 'insight-list';
            container.innerHTML = pagedItems.map((item, index) => `
                <div class="insight-row" style="animation-delay:${index * 90}ms;">
                    <div class="insight-copy">
                        <strong>${item.venueName}</strong>
                        <span>${item.meetingCount} meetings • Avg present ${item.averagePresentCount} • Avg absent ${item.averageAbsentCount}</span>
                    </div>
                    <div class="insight-meter venue-meter">
                        <div class="insight-meter-fill venue-fill" style="--target-width:${(item.meetingCount / maxCount) * 100}%"></div>
                    </div>
                    <div class="insight-value">${item.meetingCount}</div>
                </div>
            `).join('');
            renderPagination('venueMeetingsPagination', venueMeetingsPage, venueMeetingItems.length, 'changeVenueMeetingsPage');
        }

        loadStats();
    </script>
}
