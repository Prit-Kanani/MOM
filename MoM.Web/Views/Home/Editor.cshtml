@{
    ViewData["Title"] = "MoM Editor";
}

<div class="canvas-editor glass-card">
    <a href="@Url.Action("MeetingVault", "Home")" class="editor-back-link">
        <i class="fas fa-arrow-left"></i>
        <span>Back to Vault</span>
    </a>

    <div class="canvas-header">
        <div style="flex: 1;">
            <input type="text" id="meetingTitle" class="editable-title" value="Minutes of Meeting" placeholder="Document Title" />
            <div class="form-group" style="margin-top: 16px; max-width: 320px;">
                <label class="form-label">Meeting No.</label>
                <input type="text" id="meetingNumber" class="form-input" placeholder="AY-2526-01" />
            </div>
        </div>
        <div class="logo-shell">
            <div id="logoContainer" class="logo-dropzone" onclick="document.getElementById('logoUpload').click()">
                <span id="logoText" class="logo-placeholder">Upload Logo</span>
                <img id="logoPreview" class="logo-image" style="display: none;" alt="Meeting logo preview" />
                <input type="file" id="logoUpload" hidden accept="image/*" onchange="previewLogo(this)" />
            </div>
            <div class="logo-actions">
                <button type="button" class="btn-link" onclick="openLogoPreview()">Preview</button>
                <button type="button" class="btn-link logo-discard" onclick="clearLogo()">Discard</button>
            </div>
        </div>
    </div>

    <div class="editor-grid">
        <div class="form-group">
            <label class="form-label">Meeting Type <span class="required-mark">*</span></label>
            <input type="text" id="meetingType" class="form-input" placeholder="Academic Review / Department Meeting" />
        </div>
        <div class="form-group">
            <label class="form-label">Meeting Subject <span class="required-mark">*</span></label>
            <input type="text" id="meetingSubject" class="form-input" placeholder="CC / PC Meeting" />
        </div>
    </div>

    <div class="form-group">
        <label class="form-label">Description</label>
        <textarea id="meetingDescription" class="form-input" rows="2" placeholder="Brief description of the meeting..."></textarea>
    </div>

    <div class="editor-grid">
        <div class="form-group">
            <label class="form-label">Date <span class="required-mark">*</span></label>
            <input type="date" id="meetingDate" class="form-input" />
        </div>
        <div class="form-group">
            <label class="form-label">Time <span class="required-mark">*</span></label>
            <input type="time" id="meetingTime" class="form-input" />
        </div>
        <div class="form-group">
            <label class="form-label">Venue <span class="required-mark">*</span></label>
            <div class="lookup-combobox" data-lookup-type="venue">
                <input type="text" id="meetingVenue" class="form-input lookup-input" placeholder="Select or enter venue" autocomplete="off" />
                <button type="button" class="lookup-toggle" aria-label="Show venue options">
                    <i class="fas fa-chevron-down"></i>
                </button>
                <div class="lookup-menu"></div>
            </div>
        </div>
        <div class="form-group">
            <label class="form-label">Facilitator <span class="required-mark">*</span></label>
            <div class="lookup-combobox" data-lookup-type="user">
                <input type="text" id="meetingFacilitator" class="form-input lookup-input" placeholder="Select or enter facilitator" autocomplete="off" />
                <button type="button" class="lookup-toggle" aria-label="Show facilitator options">
                    <i class="fas fa-chevron-down"></i>
                </button>
                <div class="lookup-menu"></div>
            </div>
        </div>
        <div class="form-group">
            <label class="form-label">Chairperson</label>
            <div class="lookup-combobox" data-lookup-type="user">
                <input type="text" id="meetingChairperson" class="form-input lookup-input" placeholder="Select or enter chairperson" autocomplete="off" />
                <button type="button" class="lookup-toggle" aria-label="Show chairperson options">
                    <i class="fas fa-chevron-down"></i>
                </button>
                <div class="lookup-menu"></div>
            </div>
        </div>
        <div class="form-group">
            <label class="form-label">Secretary</label>
            <div class="lookup-combobox" data-lookup-type="user">
                <input type="text" id="meetingSecretary" class="form-input lookup-input" placeholder="Select or enter secretary" autocomplete="off" />
                <button type="button" class="lookup-toggle" aria-label="Show secretary options">
                    <i class="fas fa-chevron-down"></i>
                </button>
                <div class="lookup-menu"></div>
            </div>
        </div>
    </div>

    <hr style="margin: 30px 0; border: none; border-top: 1px solid #eee;" />

    <div class="form-group">
        <div class="editor-section-head">
            <label class="form-label" style="font-size: 1.2rem; color: var(--primary);">Attendees <span class="required-mark">*</span></label>
            <button type="button" class="btn-add" onclick="handleAddAttendee()">+ Add Attendee</button>
        </div>
        <div id="attendeesContainer"></div>
    </div>

    <hr style="margin: 30px 0; border: none; border-top: 1px solid #eee;" />

    <div class="form-group">
        <div class="editor-section-head">
            <label class="form-label" style="font-size: 1.2rem; color: var(--primary);">Meeting Agenda <span class="required-mark">*</span></label>
            <button type="button" class="btn-add" onclick="handleAddAgendaItem()">+ Add Agenda</button>
        </div>
        <div id="agendaItemsContainer"></div>
    </div>

    <hr style="margin: 30px 0; border: none; border-top: 1px solid #eee;" />

    <div class="form-group">
        <div class="editor-section-head">
            <label class="form-label" style="font-size: 1.2rem; color: var(--primary);">Actionable Items</label>
            <button type="button" class="btn-add" onclick="handleAddActionItem()">+ Add Action</button>
        </div>
        <div id="actionItemsContainer"></div>
    </div>

    <div class="editor-actions" style="margin-top: 50px; display: flex; gap: 20px; justify-content: flex-end;">
        <button type="button" class="btn-link" onclick="location.href='@Url.Action("MeetingVault", "Home")'">Cancel</button>
        @if (ViewBag.MeetingId != null)
        {
            <a href="/mom-api/export/@ViewBag.MeetingId" target="_blank" class="btn-link" style="padding-top: 10px;">Export PDF</a>
        }
        <button type="button" class="btn-primary" onclick="saveMeeting()">Save Meeting</button>
    </div>
</div>

<div id="logoPreviewModal" class="logo-preview-modal" hidden>
    <div class="logo-preview-backdrop"></div>
    <div class="logo-preview-dialog">
        <img id="logoPreviewModalImage" alt="Logo preview" />
    </div>
</div>

<div id="editorToast" class="editor-toast" hidden></div>

@section Scripts {
    <script>
        const API_URL = '/mom-api';
        const meetingId = @(ViewBag.MeetingId ?? "null");
        let logoBase64 = null;
        let userLookup = [];
        let venueLookup = [];
        let toastTimer = null;

        function previewLogo(input) {
            if (!input.files || !input.files[0]) return;

            const reader = new FileReader();
            reader.onload = function (e) {
                document.getElementById('logoPreview').src = e.target.result;
                document.getElementById('logoPreview').style.display = 'block';
                document.getElementById('logoText').style.display = 'none';
                logoBase64 = e.target.result.split(',')[1];
            };
            reader.readAsDataURL(input.files[0]);
        }

        function clearLogo() {
            document.getElementById('logoUpload').value = '';
            document.getElementById('logoPreview').src = '';
            document.getElementById('logoPreview').style.display = 'none';
            document.getElementById('logoText').style.display = 'block';
            logoBase64 = null;
        }

        function showEditorToast(message) {
            const toast = document.getElementById('editorToast');
            toast.textContent = message;
            toast.hidden = false;
            toast.classList.add('is-visible');

            if (toastTimer) {
                clearTimeout(toastTimer);
            }

            toastTimer = setTimeout(() => {
                toast.classList.remove('is-visible');
                setTimeout(() => {
                    toast.hidden = true;
                }, 250);
            }, 3000);
        }

        function openLogoPreview() {
            const preview = document.getElementById('logoPreview');
            if (!preview.src) {
                document.getElementById('logoUpload').click();
                return;
            }

            document.getElementById('logoPreviewModalImage').src = preview.src;
            document.getElementById('logoPreviewModal').hidden = false;
            document.body.classList.add('modal-open');
        }

        function closeLogoPreview() {
            document.getElementById('logoPreviewModal').hidden = true;
            document.getElementById('logoPreviewModalImage').src = '';
            document.body.classList.remove('modal-open');
        }

        function escapeHtml(value) {
            return (value || '')
                .replaceAll('&', '&amp;')
                .replaceAll('"', '&quot;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;');
        }

        function removeRow(button) {
            button.parentElement.remove();
        }

        function getLookupItems(type) {
            return type === 'venue' ? venueLookup : userLookup;
        }

        function findLookupByName(items, value) {
            const normalized = (value || '').trim().toLowerCase();
            return items.find(item => item.name.trim().toLowerCase() === normalized) || null;
        }

        function getLookupInput(elementOrSelector) {
            if (typeof elementOrSelector === 'string') {
                return document.getElementById(elementOrSelector);
            }

            return elementOrSelector;
        }

        function buildLookupSelection(value, items, fallbackId) {
            const trimmed = (value || '').trim();
            if (!trimmed) return null;

            const matched = findLookupByName(items, trimmed);
            if (matched) {
                return { id: matched.id, name: matched.name };
            }

            if (fallbackId) {
                return { id: fallbackId, name: trimmed };
            }

            return { id: null, name: trimmed };
        }

        function buildLookupSelectionFromInput(input, items) {
            return buildLookupSelection(input.value, items, Number(input.dataset.lookupId || 0));
        }

        function createLookupField(type, inputClass, placeholder, value = '', lookupId = '') {
            return `
                <div class="lookup-combobox" data-lookup-type="${type}">
                    <input
                        type="text"
                        class="form-input lookup-input ${inputClass}"
                        placeholder="${placeholder}"
                        value="${escapeHtml(value)}"
                        data-lookup-id="${lookupId || ''}"
                        autocomplete="off" />
                    <button type="button" class="lookup-toggle" aria-label="Show options">
                        <i class="fas fa-chevron-down"></i>
                    </button>
                    <div class="lookup-menu"></div>
                </div>
            `;
        }

        function closeLookupMenus(except = null) {
            document.querySelectorAll('.lookup-combobox').forEach(wrapper => {
                if (wrapper !== except) {
                    wrapper.classList.remove('lookup-open');
                }
            });
        }

        function renderLookupMenu(wrapper, query = '') {
            const type = wrapper.dataset.lookupType;
            const items = getLookupItems(type);
            const menu = wrapper.querySelector('.lookup-menu');
            const input = wrapper.querySelector('.lookup-input');
            const normalizedQuery = query.trim().toLowerCase();
            const filtered = items
                .filter(item => !normalizedQuery || item.name.toLowerCase().includes(normalizedQuery))
                .slice(0, 8);

            const exactMatch = findLookupByName(items, query);
            const options = filtered.map(item => `
                <button type="button" class="lookup-option" data-id="${item.id}" data-name="${escapeHtml(item.name)}">
                    <span class="lookup-option-title">${escapeHtml(item.name)}</span>
                    <span class="lookup-option-tag">Existing</span>
                </button>
            `);

            if (query.trim() && !exactMatch) {
                options.unshift(`
                    <button type="button" class="lookup-option lookup-option-create" data-id="" data-name="${escapeHtml(query.trim())}">
                        <span class="lookup-option-title">Use "${escapeHtml(query.trim())}"</span>
                        <span class="lookup-option-tag">New</span>
                    </button>
                `);
            }

            if (!options.length) {
                menu.innerHTML = '<div class="lookup-empty">Start typing to add a new option.</div>';
            } else {
                menu.innerHTML = options.join('');
            }

            if (document.activeElement === input || wrapper.classList.contains('lookup-open')) {
                closeLookupMenus(wrapper);
                wrapper.classList.add('lookup-open');
                const menuRect = menu.getBoundingClientRect();
                const wrapperRect = wrapper.getBoundingClientRect();
                const availableBelow = window.innerHeight - wrapperRect.bottom;
                const availableAbove = wrapperRect.top;
                const shouldOpenUpward = availableBelow < Math.min(menuRect.height || 280, 280) && availableAbove > availableBelow;
                wrapper.classList.toggle('lookup-open-up', shouldOpenUpward);
            }
        }

        function setLookupSelection(input, selection) {
            const target = getLookupInput(input);
            target.value = selection?.name || '';
            target.dataset.lookupId = selection?.id || '';
        }

        async function loadLookups() {
            const [usersResponse, venuesResponse] = await Promise.all([
                fetch(`${API_URL}/lookups/users`),
                fetch(`${API_URL}/lookups/venues`)
            ]);

            userLookup = usersResponse.ok ? await usersResponse.json() : [];
            venueLookup = venuesResponse.ok ? await venuesResponse.json() : [];
        }

        function addAttendee(data = { mappingId: 0, userId: null, userName: '', isPresent: true }) {
            const container = document.getElementById('attendeesContainer');
            const row = document.createElement('div');
            row.className = 'dynamic-list-row attendee-row';
            row.dataset.mappingId = data.mappingId || 0;
            row.dataset.userId = data.userId || '';
            row.innerHTML = `
                ${createLookupField('user', 'attendee-name-input', 'Select or enter attendee', data.userName, data.userId)}
                <div class="dynamic-row-meta">
                    <label class="attendee-toggle">
                        <input type="checkbox" class="attendee-present-input" ${data.isPresent ? 'checked' : ''} />
                        <span>Present</span>
                    </label>
                    <button type="button" class="btn-icon row-remove-btn" onclick="removeRow(this)"><i class="fas fa-trash"></i></button>
                </div>
            `;
            container.appendChild(row);
        }

        function canAddAttendee() {
            const rows = Array.from(document.querySelectorAll('.attendee-row'));
            if (!rows.length) return true;

            const lastRow = rows[rows.length - 1];
            const name = lastRow.querySelector('.attendee-name-input')?.value.trim();
            return Boolean(name);
        }

        function addAgendaItem(data = { id: 0, topic: '', owner: null }) {
            const container = document.getElementById('agendaItemsContainer');
            const row = document.createElement('div');
            row.className = 'dynamic-list-row agenda-row';
            row.dataset.id = data.id || 0;
            row.innerHTML = `
                <input type="text" class="form-input topic-input" placeholder="Topic" value="${escapeHtml(data.topic || '')}" style="flex: 2;" />
                ${createLookupField('user', 'owner-input', 'Select or enter owner', data.owner?.name || '', data.owner?.id || '')}
                <button type="button" class="btn-icon row-remove-btn" onclick="removeRow(this)"><i class="fas fa-trash"></i></button>
            `;
            container.appendChild(row);
        }

        function canAddAgendaItem() {
            const rows = Array.from(document.querySelectorAll('.agenda-row'));
            if (!rows.length) return true;

            const lastRow = rows[rows.length - 1];
            const topic = lastRow.querySelector('.topic-input')?.value.trim();
            const owner = lastRow.querySelector('.owner-input')?.value.trim();
            return Boolean(topic && owner);
        }

        function addActionItem(data = { id: 0, task: '', responsibility: null, deadline: '' }) {
            const container = document.getElementById('actionItemsContainer');
            const row = document.createElement('div');
            row.className = 'dynamic-list-row action-row';
            row.dataset.id = data.id || 0;
            const deadline = data.deadline ? new Date(data.deadline).toISOString().split('T')[0] : '';
            row.innerHTML = `
                <input type="text" class="form-input task-input" placeholder="Action" value="${escapeHtml(data.task || '')}" style="flex: 2;" />
                ${createLookupField('user', 'resp-input', 'Select or enter owner', data.responsibility?.name || '', data.responsibility?.id || '')}
                <input type="date" class="form-input deadline-input" value="${deadline}" style="width: 160px;" />
                <button type="button" class="btn-icon row-remove-btn" onclick="removeRow(this)"><i class="fas fa-trash"></i></button>
            `;
            container.appendChild(row);
        }

        function canAddActionItem() {
            const rows = Array.from(document.querySelectorAll('.action-row'));
            if (!rows.length) return true;

            const lastRow = rows[rows.length - 1];
            const task = lastRow.querySelector('.task-input')?.value.trim();
            const responsibility = lastRow.querySelector('.resp-input')?.value.trim();
            return Boolean(task && responsibility);
        }

        function handleAddAttendee() {
            if (!canAddAttendee()) {
                showEditorToast('Fill the current attendee row before adding another one.');
                return;
            }

            addAttendee();
        }

        function handleAddAgendaItem() {
            if (!canAddAgendaItem()) {
                showEditorToast('Fill the current agenda row before adding another one.');
                return;
            }

            addAgendaItem();
        }

        function handleAddActionItem() {
            if (!canAddActionItem()) {
                showEditorToast('Fill the current action row before adding another one.');
                return;
            }

            addActionItem();
        }

        function setLookupInputValue(id, selection) {
            setLookupSelection(id, selection);
        }

        async function loadMeeting() {
            if (!meetingId) {
                addAttendee();
                addAgendaItem();
                addActionItem();
                return;
            }

            const response = await fetch(`${API_URL}/meetings/${meetingId}`);
            if (!response.ok) throw new Error(`Request failed: ${response.status}`);

            const data = await response.json();
            document.getElementById('meetingTitle').value = data.title || 'Minutes of Meeting';
            document.getElementById('meetingNumber').value = data.meetingNumber || '';
            document.getElementById('meetingType').value = data.meetingType || '';
            document.getElementById('meetingSubject').value = data.subject || '';
            document.getElementById('meetingDescription').value = data.description || '';
            document.getElementById('meetingDate').value = data.date.split('T')[0];
            document.getElementById('meetingTime').value = data.time || '';

            setLookupInputValue('meetingVenue', data.venue);
            setLookupInputValue('meetingFacilitator', data.facilitator);
            setLookupInputValue('meetingChairperson', data.chairperson);
            setLookupInputValue('meetingSecretary', data.secretary);

            if (data.logo) {
                document.getElementById('logoPreview').src = `data:image/png;base64,${data.logo}`;
                document.getElementById('logoPreview').style.display = 'block';
                document.getElementById('logoText').style.display = 'none';
                logoBase64 = data.logo;
            }

            (data.attendees.length ? data.attendees : [{ mappingId: 0, userId: null, userName: '', isPresent: true }]).forEach(addAttendee);
            (data.agendas.length ? data.agendas : [{ id: 0, topic: '', owner: null }]).forEach(addAgendaItem);
            (data.actionItems.length ? data.actionItems : [{ id: 0, task: '', responsibility: null, deadline: '' }]).forEach(addActionItem);
        }

        function buildPayload() {
            const attendees = Array.from(document.querySelectorAll('.attendee-row'))
                .map(row => {
                    const input = row.querySelector('.attendee-name-input');
                    const selection = buildLookupSelectionFromInput(input, userLookup);
                    return {
                        mappingId: Number(row.dataset.mappingId || 0),
                        userId: selection?.id || null,
                        userName: selection?.name || null,
                        isPresent: row.querySelector('.attendee-present-input').checked
                    };
                })
                .filter(item => item.userName);

            const agendas = Array.from(document.querySelectorAll('.agenda-row'))
                .map(row => {
                    const ownerInput = row.querySelector('.owner-input');
                    return {
                        id: Number(row.dataset.id || 0),
                        topic: row.querySelector('.topic-input').value.trim(),
                        owner: buildLookupSelectionFromInput(ownerInput, userLookup)
                    };
                })
                .filter(item => item.topic && item.owner?.name);

            const actionItems = Array.from(document.querySelectorAll('.action-row'))
                .map(row => {
                    const responsibilityInput = row.querySelector('.resp-input');
                    return {
                        id: Number(row.dataset.id || 0),
                        task: row.querySelector('.task-input').value.trim(),
                        responsibility: buildLookupSelectionFromInput(responsibilityInput, userLookup),
                        deadline: row.querySelector('.deadline-input').value || null
                    };
                })
                .filter(item => item.task);

            return {
                title: document.getElementById('meetingTitle').value.trim() || 'Minutes of Meeting',
                meetingNumber: document.getElementById('meetingNumber').value.trim() || null,
                meetingType: document.getElementById('meetingType').value.trim() || null,
                subject: document.getElementById('meetingSubject').value.trim(),
                description: document.getElementById('meetingDescription').value.trim() || null,
                date: document.getElementById('meetingDate').value,
                time: document.getElementById('meetingTime').value || null,
                venue: buildLookupSelection(document.getElementById('meetingVenue').value, venueLookup, Number(document.getElementById('meetingVenue').dataset.lookupId || 0)),
                facilitator: buildLookupSelection(document.getElementById('meetingFacilitator').value, userLookup, Number(document.getElementById('meetingFacilitator').dataset.lookupId || 0)),
                chairperson: buildLookupSelection(document.getElementById('meetingChairperson').value, userLookup, Number(document.getElementById('meetingChairperson').dataset.lookupId || 0)),
                secretary: buildLookupSelection(document.getElementById('meetingSecretary').value, userLookup, Number(document.getElementById('meetingSecretary').dataset.lookupId || 0)),
                logo: logoBase64,
                attendees,
                agendas,
                actionItems
            };
        }

        async function saveMeeting() {
            const payload = buildPayload();
            if (!payload.meetingType) {
                showEditorToast('Meeting type is required.');
                return;
            }

            if (!payload.subject) {
                showEditorToast('Meeting subject is required.');
                return;
            }

            if (!payload.date) {
                showEditorToast('Meeting date is required.');
                return;
            }

            if (!payload.time) {
                showEditorToast('Meeting time is required.');
                return;
            }

            if (!payload.venue?.name) {
                showEditorToast('Venue is required.');
                return;
            }

            if (!payload.facilitator?.name) {
                showEditorToast('Facilitator is required.');
                return;
            }

            if (!payload.attendees.length) {
                showEditorToast('At least one attendee is required.');
                return;
            }

            if (!payload.agendas.length) {
                showEditorToast('At least one agenda item with owner is required.');
                return;
            }

            const method = meetingId ? 'PUT' : 'POST';
            const url = meetingId ? `${API_URL}/meetings/${meetingId}` : `${API_URL}/meetings`;

            const response = await fetch(url, {
                method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            if (!response.ok) {
                const errorText = await response.text();
                console.error('Save failed:', errorText);
                alert(`Error saving MoM.\n\n${errorText}`);
                return;
            }

            location.href = '@Url.Action("MeetingVault", "Home")';
        }

        async function initializePage() {
            try {
                await loadLookups();
                await loadMeeting();
            } catch (error) {
                console.error('Editor initialization failed:', error);
                alert('Failed to load editor data.');
            }
        }

        document.addEventListener('focusin', event => {
            if (!event.target.classList.contains('lookup-input')) {
                return;
            }

            const wrapper = event.target.closest('.lookup-combobox');
            renderLookupMenu(wrapper, event.target.value);
        });

        document.addEventListener('input', event => {
            if (!event.target.classList.contains('lookup-input')) {
                return;
            }

            event.target.dataset.lookupId = '';
            const wrapper = event.target.closest('.lookup-combobox');
            renderLookupMenu(wrapper, event.target.value);
        });

        document.addEventListener('click', event => {
            const option = event.target.closest('.lookup-option');
            if (option) {
                const wrapper = option.closest('.lookup-combobox');
                const input = wrapper.querySelector('.lookup-input');
                input.value = option.dataset.name || '';
                input.dataset.lookupId = option.dataset.id || '';
                wrapper.classList.remove('lookup-open');
                wrapper.classList.remove('lookup-open-up');
                return;
            }

            const toggle = event.target.closest('.lookup-toggle');
            if (toggle) {
                const wrapper = toggle.closest('.lookup-combobox');
                const input = wrapper.querySelector('.lookup-input');
                if (wrapper.classList.contains('lookup-open')) {
                    wrapper.classList.remove('lookup-open');
                    wrapper.classList.remove('lookup-open-up');
                } else {
                    renderLookupMenu(wrapper, input.value);
                }
                return;
            }

            if (!event.target.closest('.lookup-combobox')) {
                closeLookupMenus();
            }
        });

        document.getElementById('logoPreviewModal').addEventListener('click', event => {
            if (event.target.classList.contains('logo-preview-backdrop') || !event.target.closest('.logo-preview-dialog')) {
                closeLogoPreview();
            }
        });

        initializePage();
    </script>
}
