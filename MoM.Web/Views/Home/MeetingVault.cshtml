@{
    ViewData["Title"] = "Meeting Vault";
}

<section class="glass-card records-hero">
    <div class="dashboard-hero-head">
        <div>
            <div class="hero-kicker">Meeting Vault</div>
            <h1>Your saved MOM records</h1>
            <p>Browse, preview, edit, export, and clean up every MOM from one polished archive.</p>
        </div>
        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
            <a asp-action="Dashboard" class="btn-link">Back to Dashboard</a>
            <a asp-action="Editor" class="btn-primary" style="text-decoration: none;">Create MOM</a>
        </div>
    </div>
</section>

<div class="glass-card">
    <div class="vault-head">
        <h2 style="margin: 0;">Saved MOM Records</h2>
        <form class="vault-search" onsubmit="event.preventDefault(); applyVaultSearch();">
            <div class="vault-search-shell">
                <i class="fas fa-search"></i>
                <input type="search" id="vaultSearchInput" class="form-input vault-search-input" placeholder="Search meeting no., type, subject, venue" />
            </div>
            <button type="submit" class="vault-search-btn">Search</button>
        </form>
    </div>

    <div class="table-shell">
        <table id="meetingsTable" class="vault-table">
            <thead>
                <tr>
                    <th><button type="button" class="sort-header" onclick="sortMeetings('meetingNumber')">Meeting No.<span id="sort-meetingNumber" class="sort-indicator"></span></button></th>
                    <th><button type="button" class="sort-header" onclick="sortMeetings('meetingType')">Meeting Type<span id="sort-meetingType" class="sort-indicator"></span></button></th>
                    <th class="text-center"><button type="button" class="sort-header sort-header-center" onclick="sortMeetings('date')">Date<span id="sort-date" class="sort-indicator"></span></button></th>
                    <th><button type="button" class="sort-header" onclick="sortMeetings('venueName')">Venue<span id="sort-venueName" class="sort-indicator"></span></button></th>
                    <th><button type="button" class="sort-header" onclick="sortMeetings('subject')">Subject<span id="sort-subject" class="sort-indicator"></span></button></th>
                    <th class="text-center"><button type="button" class="sort-header sort-header-center" onclick="sortMeetings('presentCount')">Present<span id="sort-presentCount" class="sort-indicator"></span></button></th>
                    <th class="text-center"><button type="button" class="sort-header sort-header-center" onclick="sortMeetings('absentCount')">Absent<span id="sort-absentCount" class="sort-indicator"></span></button></th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody id="meetingsList">
                <tr class="table-status-row">
                    <td colspan="8" style="text-align: center;">Loading meetings...</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div id="meetingVaultPagination" class="insight-pagination" hidden></div>
</div>

@section Scripts {
    <script>
        const API_URL = '/mom-api';
        const VAULT_PAGE_SIZE = 8;
        let meetingsData = [];
        let vaultPage = 1;
        let sortState = { key: 'date', direction: 'desc' };
        let vaultSearchTerm = '';

        function formatVaultDate(value) {
            const date = new Date(value);
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        }

        function compareValues(a, b, key) {
            const aValue = a?.[key];
            const bValue = b?.[key];

            if (key === 'date') {
                return new Date(aValue) - new Date(bValue);
            }

            if (key === 'presentCount' || key === 'absentCount') {
                return (aValue || 0) - (bValue || 0);
            }

            return String(aValue || '').localeCompare(String(bValue || ''), undefined, { numeric: true, sensitivity: 'base' });
        }

        function updateSortIndicators() {
            document.querySelectorAll('.sort-indicator').forEach(indicator => {
                indicator.textContent = '';
            });

            const activeIndicator = document.getElementById(`sort-${sortState.key}`);
            if (activeIndicator) {
                activeIndicator.textContent = sortState.direction === 'asc' ? '↑' : '↓';
            }
        }

        function renderPagination() {
            const container = document.getElementById('meetingVaultPagination');
            const totalPages = Math.ceil(meetingsData.length / VAULT_PAGE_SIZE);

            if (totalPages <= 1) {
                container.hidden = true;
                container.innerHTML = '';
                return;
            }

            container.hidden = false;
            container.innerHTML = `
                <button type="button" class="pagination-btn" ${vaultPage === 1 ? 'disabled' : ''} onclick="changeVaultPage(${vaultPage - 1})">
                    <i class="fas fa-chevron-left"></i>
                    <span>Prev</span>
                </button>
                <div class="pagination-indicator">Page ${vaultPage} of ${totalPages}</div>
                <button type="button" class="pagination-btn" ${vaultPage === totalPages ? 'disabled' : ''} onclick="changeVaultPage(${vaultPage + 1})">
                    <span>Next</span>
                    <i class="fas fa-chevron-right"></i>
                </button>
            `;
        }

        function renderMeetings() {
            const list = document.getElementById('meetingsList');

            if (meetingsData.length === 0) {
                list.innerHTML = '<tr class="table-status-row"><td colspan="8" style="text-align: center;">No MOM records found. Create your first MOM to get started.</td></tr>';
                renderPagination();
                return;
            }

            const start = (vaultPage - 1) * VAULT_PAGE_SIZE;
            const pagedMeetings = meetingsData.slice(start, start + VAULT_PAGE_SIZE);

            list.innerHTML = pagedMeetings.map(m => `
                <tr>
                    <td data-label="Meeting No.">${m.meetingNumber || 'N/A'}</td>
                    <td data-label="Meeting Type">${m.meetingType || 'N/A'}</td>
                    <td data-label="Date" class="text-center">${formatVaultDate(m.date)}</td>
                    <td data-label="Venue">${m.venueName || 'N/A'}</td>
                    <td data-label="Subject"><strong>${m.subject}</strong></td>
                    <td data-label="Present" class="text-center">${m.presentCount}</td>
                    <td data-label="Absent" class="text-center">${m.absentCount}</td>
                    <td data-label="Actions" class="actions-cell actions-cell-center">
                        <a href="/Home/Preview/${m.id}" class="action-icon action-view" title="Preview MOM" aria-label="Preview MOM">
                            <i class="fas fa-eye"></i>
                        </a>
                        <a href="/Home/Editor?id=${m.id}" class="action-icon action-edit" title="Edit MOM" aria-label="Edit MOM">
                            <i class="fas fa-pen-to-square"></i>
                        </a>
                        <a href="${API_URL}/export/${m.id}" target="_blank" class="action-icon action-export" title="Export PDF" aria-label="Export PDF">
                            <i class="fas fa-file-arrow-down"></i>
                        </a>
                        <button type="button" onclick="deleteMeeting(${m.id})" class="action-icon action-delete" title="Delete MOM" aria-label="Delete MOM">
                            <i class="fas fa-trash"></i>
                        </button>
                    </td>
                </tr>
            `).join('');

            renderPagination();
        }

        function sortMeetings(key) {
            if (sortState.key === key) {
                sortState.direction = sortState.direction === 'asc' ? 'desc' : 'asc';
            } else {
                sortState = { key, direction: key === 'date' ? 'desc' : 'asc' };
            }

            meetingsData.sort((a, b) => {
                const result = compareValues(a, b, key);
                return sortState.direction === 'asc' ? result : -result;
            });

            vaultPage = 1;
            updateSortIndicators();
            renderMeetings();
        }

        function changeVaultPage(page) {
            vaultPage = page;
            renderMeetings();
        }

        async function loadMeetings() {
            try {
                const query = vaultSearchTerm ? `?search=${encodeURIComponent(vaultSearchTerm)}` : '';
                const response = await fetch(`${API_URL}/meetings${query}`);
                if (!response.ok) {
                    throw new Error(`Request failed: ${response.status}`);
                }

                meetingsData = await response.json();
                sortMeetings(sortState.key);
            } catch (error) {
                console.error('Error loading meetings:', error);
                document.getElementById('meetingsList').innerHTML = '<tr class="table-status-row"><td colspan="8" style="text-align: center; color: red;">Failed to load meetings. Make sure the API is running.</td></tr>';
            }
        }

        function applyVaultSearch() {
            vaultSearchTerm = document.getElementById('vaultSearchInput').value.trim();
            vaultPage = 1;
            loadMeetings();
        }

        async function deleteMeeting(id) {
            if (!confirm('Are you sure you want to delete this meeting?')) {
                return;
            }

            try {
                const response = await fetch(`${API_URL}/meetings/${id}`, { method: 'DELETE' });
                if (!response.ok) {
                    throw new Error(`Delete failed: ${response.status}`);
                }

                await loadMeetings();
            } catch (error) {
                console.error('Delete error:', error);
                alert('Error deleting MOM record.');
            }
        }

        loadMeetings();
    </script>
}
