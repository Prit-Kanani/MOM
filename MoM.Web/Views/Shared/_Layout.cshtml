<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Minutes of Meeting - Premium MoM System</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body>
    <header>
        <nav class="navbar">
            <div class="container">
                <a class="nav-brand" asp-area="" asp-controller="Home" asp-action="Index">MoM.Suite</a>
                <div class="nav-links">
                    <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Dashboard">Dashboard</a>
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="MeetingVault">Meeting Vault</a>
                        <a class="nav-link btn-primary" asp-area="" asp-controller="Home" asp-action="Editor">Create MOM</a>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="nav-inline-form">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="nav-link nav-logout-btn">Logout</button>
                        </form>
                    }
                    else
                    {
                        <a class="nav-link" asp-area="" asp-controller="Account" asp-action="Login">Login</a>
                        <a class="nav-link btn-primary" asp-area="" asp-controller="Account" asp-action="Register">Register</a>
                    }
                </div>
            </div>
        </nav>
    </header>
    <main role="main" class="container">
        @RenderBody()
    </main>
    <footer class="footer">
        <div class="container text-muted">
            &copy; 2026 - Minutes of Meeting Suite - Premium Design
        </div>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
